---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  tags?: string[];
}

const { title, description, publishedAt, updatedAt, tags } = Astro.props;
const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base {title} {description}>
  <article class="container post">
    <header>
      <p class="eyebrow">
        <a href="/writing/">writing</a>
      </p>
      <h1>{title}</h1>
      <p class="post-lede">{description}</p>
      <p class="post-meta mono">
        <time datetime={publishedAt.toISOString()}>{formatDate(publishedAt)}</time>
        {updatedAt && updatedAt.getTime() !== publishedAt.getTime() && (
          <>
            <span class="sep">·</span>
            <span>updated {formatDate(updatedAt)}</span>
          </>
        )}
        {tags && tags.length > 0 && (
          <>
            <span class="sep">·</span>
            <span>{tags.join(' · ')}</span>
          </>
        )}
      </p>
    </header>

    <div class="prose post-body">
      <slot />
    </div>
  </article>

  <style>
    .post {
      padding-top: var(--sp-6);
      padding-bottom: var(--sp-7);
    }
    .post header {
      margin-bottom: var(--sp-7);
      max-width: var(--content-width);
    }
    .post h1 {
      margin-top: var(--sp-2);
    }
    .post-lede {
      font-size: var(--fs-lg);
      color: var(--fg-2);
      font-family: var(--font-display);
      font-style: italic;
      max-width: var(--content-width);
    }
    .post-meta {
      color: var(--fg-3);
      font-size: var(--fs-xs);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-top: var(--sp-5);
    }
    .post-meta .sep {
      margin: 0 var(--sp-2);
      color: var(--fg-4);
    }
    .post-body {
      font-size: var(--fs-md);
    }
  </style>
</Base>
